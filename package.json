{
  "name": "jurisprudenciaia-mcp",
  "version": "0.1.0",
  "description": "Conector MCP auto-hospedado para consultar o JurisprudenciaIA usando Cloudflare Workers.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc -p tsconfig.json",
    "deploy:worker": "wrangler deploy",
    "start:server": "node dist/src/server.js",
    "start:stdio": "node dist/src/stdio.js",
    "check:codex-http": "node scripts/check-codex-http.mjs",
    "check:codex-http:all": "node scripts/check-codex-http.mjs --all-tools",
    "check:chatgpt-oauth": "node scripts/check-chatgpt-oauth.mjs",
    "verify": "npm run typecheck && npm test && npm audit --audit-level=high --omit=dev && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "helmet": "^8.3.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "wrangler": "4.114.0"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=22"
  }
}
