{
  "name": "jurisprudenciaia-mcp",
  "version": "0.1.0",
  "description": "Conector MCP auto-hospedado para consultar o JurisprudenciaIA pelo Claude.ai ou Codex usando Cloudflare Workers.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc -p tsconfig.json",
    "deploy:worker": "wrangler deploy",
    "start": "node dist/src/server.js",
    "start:stdio": "node dist/src/stdio.js",
    "check:codex-http": "node scripts/check-codex-http.mjs",
    "check:chatgpt-oauth": "node scripts/check-chatgpt-oauth.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "helmet": "8.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "wrangler": "4.103.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@hono/node-server@<2.0.5": "2.0.5"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server@<=2.0.5": "2.0.5"
    }
  }
}
